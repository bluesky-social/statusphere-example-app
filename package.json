    "@atproto/tap": "^0.1.3",
    "better-sqlite3": "^12.11.1",
    "kysely": "^0.29.3",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
